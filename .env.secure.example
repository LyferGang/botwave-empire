# Botwave Secure Configuration Template
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# TELEGRAM BOT TOKENS (from BotFather)
# ============================================
TELEGRAM_BOT_BOTI1904=
TELEGRAM_BOT_PAPERCHASER=
TELEGRAM_BOT_TRADES=
TELEGRAM_BOT_DESIGN=
TELEGRAM_BOT_CAPTAIN=
TELEGRAM_BOT_BUSINESS=
TELEGRAM_BOT_MAMMA=

# ============================================
# LLM API KEYS
# ============================================
GROQ_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
BRAVE_SEARCH_API_KEY=

# ============================================
# OLLAMA CONFIGURATION
# ============================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# ============================================
# LM STUDIO CONFIGURATION
# ============================================
LM_STUDIO_HOST=http://localhost:1234
LM_STUDIO_MODEL=huihui-qwen3.5-9b-abliterated

# ============================================
# SECURITY SECRETS (generate with openssl)
# ============================================
# Run: openssl rand -hex 32
HMAC_SECRET=
# Run: openssl rand -hex 32
JWT_SECRET=
# Run: openssl rand -hex 32
BOTWAVE_HMAC_SECRET=

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
DISPATCH_RATE_LIMIT=5
DISPATCH_WINDOW_SECONDS=3600

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# ============================================
# DATA DIRECTORY
# ============================================
DATA_DIR=/home/gringo/botwave/data
LOG_DIR=/home/gringo/botwave/logs

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=/var/log/botwave/hub.log

# ============================================
# STRIPE BILLING (TEST MODE)
# ============================================
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# ADMIN USERS (comma-separated Telegram usernames)
# ============================================
ADMIN_USERS=your_telegram_username

# ============================================
# EMAIL ALERTS (OPTIONAL)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# ============================================
# MONITORING (OPTIONAL)
# ============================================
GRAFANA_ADMIN_PASSWORD=botwave-admin
PROMETHEUS_RETENTION_DAYS=30

# ============================================
# WEBHOOK CONFIGURATION
# ============================================
WEBHOOK_VERIFY_SIGNATURE=true
WEBHOOK_SECRET=
