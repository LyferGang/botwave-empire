# Botwave Environment Configuration
# Copy this to .env and fill in your actual values
# NEVER commit .env to version control

# Telegram Bot Tokens
TELEGRAM_BOT_BOTI1904=
TELEGRAM_BOT_PAPERCHASER=
TELEGRAM_BOT_TRADES=
TELEGRAM_BOT_DESIGN=
TELEGRAM_BOT_CAPTAIN=
TELEGRAM_BOT_BUSINESS=
TELEGRAM_BOT_MAMMA=

# LLM API Keys
GROQ_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
BRAVE_SEARCH_API_KEY=

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# LM Studio Configuration
LM_STUDIO_HOST=http://localhost:1234
LM_STUDIO_MODEL=huihui-qwen3.5-9b-abliterated

# Security
HMAC_SECRET=
JWT_SECRET=
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Server Configuration
PORT=3001
HOST=0.0.0.0

# Data Directory
DATA_DIR=/home/gringo/botwave/data

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/botwave/hub.log

# Stripe (for billing - use test keys in development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Alerts (optional)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM_EMAIL=
ALERT_TO_EMAIL=

# Monitoring (optional)
GRAFANA_ADMIN_PASSWORD=botwave-admin
PROMETHEUS_RETENTION_DAYS=30
