FROM node:20-slim
RUN apt-get update && apt-get install -y git python3 bash jq
WORKDIR /workspace
# Install MCP SDK and local tools
RUN npm install -g @modelcontextprotocol/sdk
# Placeholder for local script entrypoint
COPY scripts/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
